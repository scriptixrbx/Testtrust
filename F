-- Функция замены текста
local function ReplaceText(obj, old, new)
    if obj.Text == old then
        obj.Text = new
        return true
    elseif obj.Text:find(old) then
        obj.Text = obj.Text:gsub(old, new)
        return true
    end
    return false
end

-- Функция для поиска и замены ника в трейде
local function ReplaceInTrade(old, new)
    local count = 0
    local replaced = {}
    
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            if v.Text and (v.Text == old or v.Text:find(old)) then
                -- Проверяем что это в трейде
                local parent = v.Parent
                local inTrade = false
                
                while parent do
                    local name = parent.Name:lower()
                    local class = parent.ClassName:lower()
                    
                    if name:find("trade") or class:find("trade") then
                        inTrade = true
                        break
                    end
                    parent = parent.Parent
                end
                
                if inTrade then
                    ReplaceText(v, old, new)
                    count = count + 1
                    table.insert(replaced, v.Name)
                end
            end
        end
    end
    
    return count
end

-- Функция для замены в чате/уведомлениях о трейде
local function ReplaceInChat(old, new)
    local count = 0
    
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            if v.Text and v.Text:find(old) then
                local parent = v.Parent
                
                while parent do
                    local name = parent.Name:lower()
                    
                    -- Проверяем сообщения о трейде
                    if name:find("notif") or name:find("message") or name:find("trade") then
                        ReplaceText(v, old, new)
                        count = count + 1
                        break
                    end
                    parent = parent.Parent
                end
            end
        end
    end
    
    return count
end

-- Главная функция замены
local function ReplaceAll()
    local old = OldNameBox.Text
    local new = NewNameBox.Text
    
    if old == "" or new == "" then
        return
    end
    
    local tradeCount = ReplaceInTrade(old, new)
    local chatCount = ReplaceInChat(old, new)
    
    if tradeCount > 0 then
        StatusLabel.Text = "✅ Trade: " .. tradeCount .. " | Chat: " .. chatCount
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    end
end

-- Бесконечный цикл проверки (проверяет каждые 100мс)
task.spawn(function()
    while task.wait(0.1) do
        ReplaceAll()
    end
end)

