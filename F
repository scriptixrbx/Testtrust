-- Функция для проверки, является ли объект ником игрока
local function IsPlayerName(object)
    -- Проверяем, находится ли объект в Head (голова игрока)
    local parent = object.Parent
    while parent do
        if parent:IsA("Model") and game.Players:GetPlayerFromCharacter(parent) then
            return true
        end
        parent = parent.Parent
    end
    
    -- Дополнительные проверки для разных игр
    -- Проверка по имени объекта (часто ники находятся в BillBoardGui, NameTag и т.д.)
    local objectName = object.Name:lower()
    if objectName:find("name") or objectName:find("tag") or objectName:find("nick") or objectName:find("user") then
        return true
    end
    
    -- Проверка родительского объекта
    if object.Parent then
        local parentName = object.Parent.Name:lower()
        if parentName:find("nametag") or parentName:find("billboard") or parentName:find("head") or parentName:find("humanoid") then
            return true
        end
    end
    
    return false
end

-- Функция замены текста только для ников
local function ReplaceText(obj, old, new)
    if not IsPlayerName(obj) then
        return false
    end
    
    if obj.Text == old then
        obj.Text = new
        return true
    elseif obj.Text:find(old) then
        obj.Text = obj.Text:gsub(old, new)
        return true
    end
    
    return false
end

-- Основная функция замены
local function ReplaceAll(old, new)
    local count = 0
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            if ReplaceText(v, old, new) then
                count = count + 1
            end
        end
    end
    return count
end

-- Кнопка Replace
ReplaceButton.MouseButton1Click:Connect(function()
    local old = OldNameBox.Text
    local new = NewNameBox.Text
    
    if old == "" then
        StatusLabel.Text = "Enter old nickname!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    local count = ReplaceAll(old, new)
    StatusLabel.Text = "Replaced: " .. count .. " nicknames"
    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
end)

-- Отслеживание новых объектов
game.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
        ReplaceText(v, OldNameBox.Text, NewNameBox.Text)
    end
end)

