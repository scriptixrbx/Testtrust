-- Функция для проверки, находится ли объект в трейд меню
local function IsInTradeMenu(object)
    local parent = object.Parent
    while parent do
        local parentName = parent.Name:lower()
        local className = parent.ClassName:lower()
        
        -- Проверяем различные названия трейд меню в Adopt Me
        if parentName:find("trade") or parentName:find("trading") then
            return true
        end
        
        -- Проверяем ScreenGui трейда
        if parent:IsA("ScreenGui") and (parentName:find("trade") or parentName:find("trading")) then
            return true
        end
        
        -- Проверяем по классу
        if className:find("trade") then
            return true
        end
        
        parent = parent.Parent
    end
    return false
end

-- Функция замены текста только в трейде
local function ReplaceText(obj, old, new)
    -- Проверяем только объекты в трейд меню
    if not IsInTradeMenu(obj) then
        return false
    end
    
    if obj.Text == old then
        obj.Text = new
        return true
    elseif obj.Text:find(old) then
        obj.Text = obj.Text:gsub(old, new)
        return true
    end
    
    return false
end

-- Основная функция замены
local function ReplaceAll(old, new)
    local count = 0
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            if ReplaceText(v, old, new) then
                count = count + 1
            end
        end
    end
    return count
end

-- Кнопка Replace
ReplaceButton.MouseButton1Click:Connect(function()
    local old = OldNameBox.Text
    local new = NewNameBox.Text
    
    if old == "" then
        StatusLabel.Text = "Enter old nickname!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    local count = ReplaceAll(old, new)
    StatusLabel.Text = "Replaced: " .. count .. " in trade"
    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
end)

-- Отслеживание новых объектов в трейде
game.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
        if IsInTradeMenu(v) then
            ReplaceText(v, OldNameBox.Text, NewNameBox.Text)
        end
    end
end)

