-- Функция для проверки, находится ли объект в трейд меню
local function IsInTradeMenu(object)
    local parent = object.Parent
    while parent do
        local parentName = parent.Name:lower()
        local className = parent.ClassName:lower()
        
        if parentName:find("trade") or parentName:find("trading") then
            return true
        end
        
        if parent:IsA("ScreenGui") and (parentName:find("trade") or parentName:find("trading")) then
            return true
        end
        
        if className:find("trade") then
            return true
        end
        
        parent = parent.Parent
    end
    return false
end

-- Функция для проверки, является ли объект сообщением в чате/уведомлением
local function IsChatMessage(object)
    local parent = object.Parent
    while parent do
        local parentName = parent.Name:lower()
        
        -- Проверяем чат и уведомления
        if parentName:find("chat") or parentName:find("message") or parentName:find("notification") or parentName:find("notif") then
            return true
        end
        
        -- Проверяем TextChatService
        if parent:IsA("TextChatService") or parent:IsA("Chat") then
            return true
        end
        
        -- Проверяем системные сообщения (типа "кинул трейд")
        if parent:IsA("ScreenGui") and parentName:find("notif") then
            return true
        end
        
        parent = parent.Parent
    end
    return false
end

-- Функция замены текста
local function ReplaceText(obj, old, new)
    if obj.Text == old then
        obj.Text = new
        return true
    elseif obj.Text:find(old) then
        obj.Text = obj.Text:gsub(old, new)
        return true
    end
    return false
end

-- Функция замены везде (трейд + сообщения)
local function ReplaceInObject(obj, old, new)
    if not obj:IsA("TextLabel") and not obj:IsA("TextButton") and not obj:IsA("TextBox") then
        return false
    end
    
    -- Меняем в трейде
    if IsInTradeMenu(obj) then
        return ReplaceText(obj, old, new)
    end
    
    -- Меняем в сообщениях чата
    if IsChatMessage(obj) then
        return ReplaceText(obj, old, new)
    end
    
    return false
end

-- Функция полной замены
local function ReplaceAll(old, new)
    local count = 0
    for _, v in ipairs(game:GetDescendants()) do
        if ReplaceInObject(v, old, new) then
            count = count + 1
        end
    end
    return count
end

-- Авто-замена при изменении текста в полях
OldNameBox:GetPropertyChangedSignal("Text"):Connect(function()
    local old = OldNameBox.Text
    local new = NewNameBox.Text
    if old ~= "" and new ~= "" then
        local count = ReplaceAll(old, new)
        StatusLabel.Text = "🟢 Auto-replaced: " .. count
        task.wait(1)
        StatusLabel.Text = "🟢 Auto-replace active"
    end
end)

NewNameBox:GetPropertyChangedSignal("Text"):Connect(function()
